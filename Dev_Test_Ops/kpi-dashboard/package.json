{
  "name": "kpi-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "dev:uat": "vite --mode uat",
    "dev:prod": "vite --mode prod",
    "local:dev": "vite --mode dev --host 127.0.0.1 --port 4173 --strictPort",
    "local:uat": "vite --mode uat --host 127.0.0.1 --port 4174 --strictPort",
    "local:prod": "vite --mode prod --host 127.0.0.1 --port 4175 --strictPort",
    "build": "npm run build:prod",
    "build:dev": "tsc -p tsconfig.app.json && vite build --mode dev",
    "build:uat": "tsc -p tsconfig.app.json && vite build --mode uat",
    "build:prod": "tsc -p tsconfig.app.json && vite build --mode prod",
    "preview:dev": "vite preview --host 127.0.0.1 --port 4273 --strictPort",
    "preview:uat": "vite preview --host 127.0.0.1 --port 4274 --strictPort",
    "preview:prod": "vite preview --host 127.0.0.1 --port 4275 --strictPort",
    "local:start-all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-local-envs.ps1",
    "local:stop-all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-local-envs.ps1",
    "snapshot:sync": "node .\\scripts\\sync-workbook-snapshot.mjs",
    "promote:check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-promotion-readiness.ps1",
    "promote:uat": "powershell -ExecutionPolicy Bypass -File .\\scripts\\promote-branch.ps1 -SourceBranch dev -TargetBranch uat",
    "promote:prod": "powershell -ExecutionPolicy Bypass -File .\\scripts\\promote-branch.ps1 -SourceBranch uat -TargetBranch main",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.mjs",
    "test:run": "vitest run --config vitest.config.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
